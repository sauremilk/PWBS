# ================================================================
# PWBS Self-Hosting  Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
# ================================================================

# -- Allgemein ---------------------------------------------------
# ENVIRONMENT=production
# LOG_LEVEL=INFO
# CORS_ORIGINS=https://pwbs.example.com
# API_PORT=8000
# FRONTEND_PORT=3000

# -- PostgreSQL --------------------------------------------------
POSTGRES_DB=pwbs
POSTGRES_USER=pwbs
POSTGRES_PASSWORD=CHANGE_ME_SECURE_RANDOM_PASSWORD

# -- Neo4j -------------------------------------------------------
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_SECURE_RANDOM_PASSWORD

# -- Weaviate ----------------------------------------------------
WEAVIATE_API_KEY=CHANGE_ME_SECURE_RANDOM_KEY

# -- Authentifizierung (PFLICHT) ---------------------------------
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
JWT_ALGORITHM=RS256
# JWT_PRIVATE_KEY=  # PEM-encodiert, base64
# JWT_PUBLIC_KEY=   # PEM-encodiert, base64

# -- Verschluesselung (PFLICHT) ----------------------------------
ENCRYPTION_MASTER_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# -- LLM-Provider ------------------------------------------------
# Optionen: claude | gpt4 | ollama
LLM_PROVIDER=claude

# Cloud-LLMs (nur wenn LLM_PROVIDER=claude oder gpt4):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama (nur wenn LLM_PROVIDER=ollama):
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.1

# -- Container-Images (optional) ---------------------------------
# PWBS_IMAGE=ghcr.io/sauremilk/pwbs-backend:latest
# PWBS_FRONTEND_IMAGE=ghcr.io/sauremilk/pwbs-frontend:latest

# -- Sentry Error-Tracking (LAUNCH-OPS-001) ---------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=1.0
