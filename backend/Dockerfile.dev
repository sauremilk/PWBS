# PWBS Backend  Development Dockerfile
# Hot-reload via uvicorn --reload, source mounted as volume

FROM python:3.12.10-slim

WORKDIR /app

# System dependencies for asyncpg, cryptography
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY pyproject.toml ./
RUN pip install --no-cache-dir -e ".[dev,llm,vector,graph]"

# Source is mounted as volume in docker-compose, not copied
# COPY . . is intentionally omitted for dev

EXPOSE 8000

CMD ["uvicorn", "pwbs.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
