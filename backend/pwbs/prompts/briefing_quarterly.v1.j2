{% endif %}

{% for a in assumptions %}
- **{{ a.title }}** – Status: {{ a.status }}{% if a.reason %} ({{ a.reason }}){% endif %}{% if a.changed_at %} | Geändert: {{ a.changed_at }}{% endif %}{% if a.evidence_count %} | {{ a.evidence_count }} Belege{% endif %}
{% endfor %}
{% if not assumptions %}
- Keine Annahmen im Tracking.
{% endif %}

