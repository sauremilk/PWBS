# ============================================================================
# PWBS  Umgebungsvariablen
# ============================================================================
# Kopiere diese Datei nach .env und fuege echte Werte ein:
#   cp .env.example .env
#
# NIEMALS .env committen! Sie steht in .gitignore.
# ============================================================================

#  Allgemein
# Pflicht | Werte: development, staging, production
# Im Production-Modus werden /docs und /redoc deaktiviert.
ENVIRONMENT=development

# Pflicht | Log-Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Pflicht | JSON-Array erlaubter CORS-Origins
CORS_ORIGINS=["http://localhost:3000"]

#  PostgreSQL
# Pflicht | Format: postgresql+asyncpg://user:password@host:port/dbname
# Fuer lokale Entwicklung mit docker-compose passt der Default.
DATABASE_URL=postgresql+asyncpg://pwbs:pwbs_dev@localhost:5432/pwbs

#  Weaviate (Vektorsuche)
# Pflicht | URL der Weaviate-Instanz (HTTP)
WEAVIATE_URL=http://localhost:8080

#  Neo4j (Knowledge Graph)
# Pflicht | Bolt-URI der Neo4j-Instanz
NEO4J_URI=bolt://localhost:7687

# Pflicht | Neo4j-Benutzername
NEO4J_USER=neo4j

# Pflicht | Neo4j-Passwort (fuer lokale Entwicklung: dev_password)
NEO4J_PASSWORD=dev_password

#  Redis
# Optional (Phase 3) | Redis-URL fuer Celery Task Queue
REDIS_URL=redis://localhost:6379/0

#  LLM-APIs
# Pflicht* | Anthropic Claude API Key (*pflicht, es sei denn nur Ollama)
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=

# Optional | OpenAI API Key (Embeddings + GPT-4 Fallback)
# Format: sk-...
OPENAI_API_KEY=

#  Authentifizierung
# Pflicht | Geheimer Schluessel fuer JWT-Token-Signierung (Fallback bei HS256)
# Generiere mit: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=changeme-generate-a-secure-random-string

# Pflicht | JWT-Algorithmus (RS256 in Production, HS256 als Dev-Fallback)
JWT_ALGORITHM=RS256

# Pflicht | Access-Token-Gueltigkeitsdauer in Minuten
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Pflicht | Refresh-Token-Gueltigkeitsdauer in Tagen
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Pflicht (RS256) | RSA Private Key (PEM-Format, mehrzeilig mit \n)
# Generiere mit: openssl genrsa -out private.pem 2048
# Setze als einzeilig: awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem
JWT_PRIVATE_KEY=

# Pflicht (RS256) | RSA Public Key (PEM-Format, mehrzeilig mit \n)
# Generiere mit: openssl rsa -in private.pem -pubout -out public.pem
JWT_PUBLIC_KEY=
#  Verschluesselung (Envelope Encryption, AES-256)
# Pflicht | Master Encryption Key (KEK) zum Wrappen der per-User Data Keys
# Generiere mit: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_MASTER_KEY=

#  OAuth2 Connector Credentials
# Optional | Google Calendar + Gmail Connector
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional | Notion Connector
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Optional | Zoom Connector
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Optional | Slack Connector
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

#  Email-Service (TASK-176)
# Optional | Provider: "smtp" (default) oder "sendgrid"
EMAIL_PROVIDER=smtp

# Optional | SMTP-Server-Konfiguration
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Optional | SendGrid API Key (nur wenn EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# Optional | Absender-Konfiguration
EMAIL_FROM_ADDRESS=noreply@pwbs.app
EMAIL_FROM_NAME=PWBS

# Pflicht (Production) | DSGVO-Links in jeder Email
EMAIL_UNSUBSCRIBE_URL=http://localhost:3000/settings/notifications
EMAIL_IMPRESSUM_URL=http://localhost:3000/impressum

#  Plausible Analytics (TASK-179)
# Optional | Domain fuer Plausible Event-Tracking (leer = deaktiviert)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Optional | Plausible Script-URL (Default: https://plausible.io/js/script.js)
# Fuer Self-Hosted: http://localhost:8100/js/script.js
NEXT_PUBLIC_PLAUSIBLE_SRC=
